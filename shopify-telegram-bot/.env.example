TELEGRAM_BOT_TOKEN=

# xAI (Grok) — https://console.x.ai — model is fixed in code: grok-4.3
XAI_API_KEY=

# Set automatically on Railway/Render Web; enables GET / and /health for health checks
# PORT=

# Optional — Supabase (Postgres + API). Bot process still runs on Railway/Render/Fly/etc.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Store: subdomain only or full hostname
SHOPIFY_STORE=yourstore.myshopify.com

# Option A — Legacy custom app (Admin API access token, often shpat_…)
SHOPIFY_ACCESS_TOKEN=

# Option B — Dev Dashboard app (use when you only have Client ID + Secret)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Dev Dashboard app version scopes: read_products, write_products (for /shop, /products, /find, etc.)
